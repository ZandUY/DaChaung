s.REQUEST_URL+\"/admin/xt_intro_msg/queryDataDetail\",\r\n\t\t\t\tasync: false,\r\n\t\t\t\tdata : {\r\n\t\t\t\t\t'id':that.id,\r\n\t\t\t\t\t'loginToken':that.currentLoginToken,\r\n\t\t\t\t},\r\n\t\t\t\tsuccess : function(result) {\r\n\t\t\t\t\tthat.title=result.title;\r\n\t\t\t\t\tthat.fmImg=result.fmImg;\r\n\t\t\t\t\tthat.introDetail=result.introDetail;\r\n\t\t\t\t\tthat.celphone=result.celphone;\r\n\t\t\t\t\tthat.address=result.address;\r\n\t\t\t\t\tthat.email=result.email;\r\n\t\t\t\t\tsetEditorHtml('introDetail',result.introDetail)\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t},\r\n\t\tsubmitData(){\r\n\t\t\tvar that = this;\r\n\t\t\tvar title = that.title;\r\n\t\t\tvar fmImg = getFileVal2('fmImg');\r\n\t\t\tvar introDetail = getEditVal('introDetail');\r\n\t\t\tvar celphone = that.celphone;\r\n\t\t\tvar address = that.address;\r\n\t\t\tvar email = that.email;\r\n\t\t\t$.ajax({\r\n\t\t\t\ttype : 'post',\r\n\t\t\t\turl : this.REQUEST_URL+\"/admin/xt_intro_msg/update_submit\",\r\n\t\t\t\tasync: false,\r\n\t\t\t\tdata : {\r\n\t\t\t\t\t'id':that.id,\r\n\t\t\t\t\t'title':title,\r\n\t\t\t\t\t'fmImg':fmImg,\r\n\t\t\t\t\t'introDetail':introDetail,\r\n\t\t\t\t\t'celphone':celphone,\r\n\t\t\t\t\t'address':address,\r\n\t\t\t\t\t'email':email,\r\n\t\t\t\t\t'loginToken':that.currentLoginToken,\r\n\t\t\t\t},\r\n\t\t\t\tsuccess : function(result) {\r\n\t\t\t\t\talert(result.msg);\r\n\t\t\t\t\tif(result.code==1){\r\n\t\t\t\t\t\tthat.$router.go(-1);\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t},\r\n\t}\r\n};\r\n\r\n</script>\r\n<style type=\"text/css\" src=\"../../../assets/imgupload/css/dropzone.min.css?t=44\" scoped></style>\r\n<style scoped>\r\n\t.edit-page-div {\r\n\tbackground: #f8fafc;\r\n\tmin-height: 100vh;\r\n\tpadding: 30px;\r\n\t}\r\n\t/* 主卡片容器 */\r\n\t.box-card {\r\n\tmax-width: 1000px;\r\n\tmargin: 0 auto;\r\n\tborder-radius: 12px;\r\n\tbox-shadow: 0 6px 18px rgba(62, 86, 206, 0.08);\r\n\tbackground: linear-gradient(145deg, #ffffff 0%, #f9fbfd 100%);\r\n\t}\r\n\t/* 标题样式 */\r