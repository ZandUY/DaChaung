项目代码\\项目代码\\foods_service-vue\\src\\views\\admin\\yyxcs_msg\\update_page.vue"],"sourcesContent":["\r\n\r\n<template>\r\n\t<div class=\"edit-page-div\">\r\n\t\t<div class=\"box-card\">\r\n\t\t\t<h2 class=\"edit-page-div-h2\">营养小常识-修改</h2>\r\n\t\t\t<div class=\"edit-form-div\" id=\"titleForm\">\r\n\t\t\t\t<div  class=\"edit-form-name\">标题</div>\r\n\t\t\t\t<div class=\"edit-form-div2\">\r\n\t\t\t\t\t<div class=\"edit-form-div3\">\r\n\t\t\t\t\t\t<el-input type=\"text\"  placeholder=\"请输入标题\" name=\"title\" v-model=\"title\" class=\"\" id=\"title\"></el-input>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"edit-form-div\" id=\"fmImgForm\">\r\n\t\t\t\t<div  class=\"edit-form-name\">封面图</div>\r\n\t\t\t\t<div class=\"edit-form-div2\">\r\n\t\t\t\t\t<div class=\"edit-form-div3\">\r\n\t\t\t\t\t\t<div id=\"fmImg\" class=\"dropzone\" data-id=\"fmImg\" max-num=\"1\" file-type=\"1\" max-size=\"1000\" init-val=\"\" :request-url=\"REQUEST_URL\" :init-val=\"fmImg\"></div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"edit-form-div\" id=\"csContentForm\">\r\n\t\t\t\t<div  class=\"edit-form-name\">常识内容</div>\r\n\t\t\t\t<div class=\"edit-form-div2\">\r\n\t\t\t\t\t<div class=\"edit-form-div3\">\r\n\t\t\t\t\t\t<div class=\"editorDiv\" id=\"csContent\" data-id=\"csContent\"></div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"edit-page-div-btn\">\r\n\t\t\t\t<el-button type=\"primary\" @click=\"submitData\" >提交</el-button>\r\n\t\t\t\t<el-button type=\"default\" onclick=\"javascript:history.back(-1);\"  >返回</el-button>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</div>\r\n</template>\r\n\r\n<script>\r\nimport $ from 'jquery'\r\nimport {utils} from '../../../assets/listutils.js'\r\nimport {admin_utils} from '../../../assets/admin/admin_utils.js'\r\nimport {getFileVal2,initDropZone,setZoneImg} from '../../../assets/imgupload/js/imgupload.js'\r\nimport {initAllEditor,getEditVal,setEditorHtml} from '../../../assets/wangeditor/editor_utils.js'\r\nexport default {\r\n\tcomponents: {\r\n\t},\r\n\tdata() {\r\n\t\treturn {\r\n\t\t\tcurrentLoginToken:'',\r\n\t\t\tid:'',\r\n\t\t\ttitle:'',\r\n\t\t\tfmImg:'',\r\n\t\t\tcsContent:'',\r\n\t\t};\r\n\t},\r\n\tmounted() {\r\n\t\tvar that = this;\r\n\t\tthat.currentLoginToken=utils.getCookie('loginToken');\r\n\t\tthat.id= that.$route.query.id;\r\n\t\tvar fmImgDrop = initDropZone('fmImg');\r\n\t\tinitAllEditor(this.REQUEST_URL,'csContent');\r\n\t\tthat.queryDataDetail();\r\n\t\tsetZoneImg(fmImgDrop,that.fmImg);\r\n\t\tsetEditorHtml('csContent',that.csContent)\r\n\t},\r\n\tmethods:{\r\n\t\tqueryDataDetail(){\r\n\t\t\tvar that = this;\r\n\t\t\t$.ajax({\r\n\t\t\t\ttype : 'get',\r\n\t\t\t\turl : this.REQUEST_URL+\"/admin/yyxcs_msg/queryDataDetail\",\r\n\t\t\t\tasync: false,\r\n\t\t\t\tdata : {\r\n\t\t\t\t\t'id':that.id,\r\n\t\t\t\t\t'loginToken':that.currentLoginToken,\r\n\t\t\t\t},\r\n\t\t\t\tsuccess : function(result) {\r\n\t\t\t\t\tthat.title=result.title;\r\n\t\t\t\t\tthat.fmImg=result.fmImg;\r\n\t\t\t\t\tthat.csContent=result.csContent;\r\n\t\t\t\t\tsetEditorHtml('csContent',result.csContent)\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t},\r\n\t\tsubmitData(){\r\n\t\t\tvar that = this;\r\n\t\t\tvar title = that.title;\r\n\t\t\tvar fmImg = getFileVal2('fmImg');\r\n\t\t\tvar csContent = getEditVal('csContent');\r\n\t\t\t$.ajax({\r\n\t\t\t\ttype : 'post',\r\n\t\t\t\turl : this.REQUEST_URL+\"/admin/yyxcs_msg/update_submit\",\r\n\t\t\t\tasync: false,\r\n\t\t\t\tdata : {\r\n\t\t\t\t\t'id':that.id,\r\n\t\t\t\t\t'title':title,\r\n\t\t\t\t\t'fmImg':fmImg,\r\n\t\t\t\t\t'csContent':csContent,\r\n\t\t\t\t\t'loginToken':that.currentLoginToken,\r\n\t\t\t\t},\r\n\t\t\t\tsuccess : function(result) {\r\n\t\t\t\t\talert(result.msg);\r\n\t\t\t\t\tif(result.code==1){\r\n\t\t\t\t\t\tthat.$router.go(-1);\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t},\r\n\t}\r\n};\r\n\r\n</script>\r\n<style type=\"text/css\" src=\"../../../assets/imgupload/css/dropzone.min.css?t=44\" scope