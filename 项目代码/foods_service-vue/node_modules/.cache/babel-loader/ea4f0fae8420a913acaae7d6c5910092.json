ate>\r\n\r\n<script>\r\nimport $ from 'jquery'\r\nimport {utils} from '../../../assets/listutils.js'\r\nimport {admin_utils} from '../../../assets/admin/admin_utils.js'\r\nimport {initAllEditor,getEditVal,setEditorHtml} from '../../../assets/wangeditor/editor_utils.js'\r\nexport default {\r\n\tcomponents: {\r\n\t},\r\n\tdata() {\r\n\t\treturn {\r\n\t\t\tcurrentLoginToken:'',\r\n\t\t\tid:'',\r\n\t\t\ttitle:'',\r\n\t\t\tsubtitle:'',\r\n\t\t\tpostDetail:'',\r\n\t\t};\r\n\t},\r\n\tmounted() {\r\n\t\tvar that = this;\r\n\t\tthat.currentLoginToken=utils.getCookie('loginToken');\r\n\t\tthat.id= that.$route.query.id;\r\n\t\tinitAllEditor(this.REQUEST_URL,'postDetail');\r\n\t\tthat.queryDataDetail();\r\n\t\tsetEditorHtml('postDetail',that.postDetail)\r\n\t},\r\n\tmethods:{\r\n\t\tqueryDataDetail(){\r\n\t\t\tvar that = this;\r\n\t\t\t$.ajax({\r\n\t\t\t\ttype : 'get',\r\n\t\t\t\turl : this.REQUEST_URL+\"/user/post_msg/queryDataDetail\",\r\n\t\t\t\tasync: false,\r\n\t\t\t\tdata : {\r\n\t\t\t\t\t'id':that.id,\r\n\t\t\t\t\t'loginToken':that.currentLoginToken,\r\n\t\t\t\t},\r\n\t\t\t\tsuccess : function(result) {\r\n\t\t\t\t\tthat.title=result.title;\r\n\t\t\t\t\tthat.subtitle=result.subtitle;\r\n\t\t\t\t\tthat.postDetail=result.postDetail;\r\n\t\t\t\t\t$(\"#subtitle\").val(result.subtitle);\r\n\t\t\t\t\tsetEditorHtml('postDetail',result.postDetail)\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t},\r\n\t\tsubmitData(){\r\n\t\t\tvar that = this;\r\n\t\t\tvar title = that.title;\r\n\t\t\tvar subtitle = that.subtitle;\r\n\t\t\tvar postDetail = getEditVal('postDetail');\r\n\t\t\t$.ajax({\r\n\t\t\t\ttype : 'post',\r\n\t\t\t\turl : this.REQUEST_URL+\"/user/post_msg/update_submit\",\r\n\t\t\t\tasync: false,\r\n\t\t\t\tdata : {\r\n\t\t\t\t\t'id':that.id,\r\n\t\t\t\t\t'title':title,\r\n\t\t\t\t\t'subtitle':subtitle,\r\n\t\t\t\t\t'postDetail':postDetail,\r\n\t\t\t\t\t'loginToken':that.currentLoginToken,\r\n\t\t\t\t},\r\n\t\t\t\tsuccess : function(result) {\r\n\t\t\t\t\talert(result.msg);\r\n\t\t\t\t\tif(