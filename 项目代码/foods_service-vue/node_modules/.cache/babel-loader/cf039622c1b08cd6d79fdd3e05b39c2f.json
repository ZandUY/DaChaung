that.currentLoginToken,\r\n\t\t\t\t},\r\n\t\t\t\tsuccess : function(result) {\r\n\t\t\t\t\tthat.typeName=result.typeName;\r\n\t\t\t\t\tthat.mfzxh=result.mfzxh;\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t},\r\n\t\tsubmitData(){\r\n\t\t\tvar that = this;\r\n\t\t\tvar typeName = that.typeName;\r\n\t\t\tvar mfzxh = that.mfzxh;\r\n\t\t\t$.ajax({\r\n\t\t\t\ttype : 'post',\r\n\t\t\t\turl : this.REQUEST_URL+\"/admin/yd_type_msg/update_submit\",\r\n\t\t\t\tasync: false,\r\n\t\t\t\tdata : {\r\n\t\t\t\t\t'id':that.id,\r\n\t\t\t\t\t'typeName':typeName,\r\n\t\t\t\t\t'mfzxh':mfzxh,\r\n\t\t\t\t\t'loginToken':that.currentLoginToken,\r\n\t\t\t\t},\r\n\t\t\t\tsuccess : function(result) {\r\n\t\t\t\t\talert(result.msg);\r\n\t\t\t\t\tif(result.code==1){\r\n\t\t\t\t\t\tthat.$router.go(-1);\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t},\r\n\t}\r\n};\r\n\r\n</script>\r\n<style scoped>\r\n\t.edit-page-div {\r\n\tbackground: #f8fafc;\r\n\tmin-height: 100vh;\r\n\tpadding: 30px;\r\n\t}\r\n\t/* 主卡片容器 */\r\n\t.box-card {\r\n\tmax-width: 1000px;\r\n\tmargin: 0 auto;\r\n\tborder-radius: 12px;\r\n\tbox-shadow: 0 6px 18px rgba(62, 86, 206, 0.08);\r\n\tbackground: linear-gradient(145deg, #ffffff 0%, #f9fbfd 100%);\r\n\t}\r\n\t/* 标题样式 */\r\n\t.edit-page-div-h2 {\r\n\tcolor: #2d3441;\r\n\tfont-size: 24px;\r\n\ttext-align: center;\r\n\tpadding: 24px 0;\r\n\tmargin: 0;\r\n\tborder-bottom: 1px solid #f0f2f7;\r\n\t}\r\n\t/* 表单项容器 */\r\n\t.edit-form-div {\r\n\tdisplay: flex;\r\n\tflex-wrap: wrap;\r\n\tpadding: 18px 30px;\r\n\tborder-bottom: 1px solid #f0f2f7;\r\n\ttransition: background 0.3s;\r\n\t}\r\n\t.edit-form-div:hover {\r\n\tbackground: #f8fafc;\r\n\t}\r\n\t/* 表单标签 */\r\n\t.edit-form-name {\r\n\twidth: 160px;\r\n\tfont-weight: 600;\r\n\tcolor: #5a5e66;\r\n\tpadding: 10px 0;\r\n\tfont-size: 14px;\r\n\t}\r\n\t/* 输入控件容器 */\r\n\t.edit-form-div2 {\r\n\tflex: 1;\r\n\tmin-width: 300px;\r\n\t}\r\n\t.edit-form-div3 {\r\n\tmax-width: 600px;\r\n\t}\r\n\t/* Element输入框增强 */\r\n\t.el-input__inner,\r\n\t.el-textarea__in