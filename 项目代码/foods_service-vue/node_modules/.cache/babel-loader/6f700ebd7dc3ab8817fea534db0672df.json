ation.js'\r\nexport default {\r\n\tcomponents: {\r\n\t},\r\n\tdata() {\r\n\t\treturn {\r\n\t\t\tcurrentLoginToken:'',\r\n\t\t\tcurrentLoginId:'',\r\n\t\t\tcurrentLoginType:'',\r\n\t\t\treplyContent:'',\r\n\t\t\treplyTime1:'',\r\n\t\t\treplyTime2:'',\r\n\t\t\tdataList:[],\r\n\t\t};\r\n\t},\r\n\tmounted() {\r\n\t\tvar that = this;\r\n\t\tthat.currentLoginToken=utils.getCookie('loginToken');\r\n\t\tthat.currentLoginId=utils.getCookie('loginId');\r\n\t\tthat.currentLoginType=utils.getCookie('loginType');\r\n\t\tthat.ajaxList(1);\r\n\t},\r\n\tmethods:{\r\n\t\tdel(e){\r\n\t\t\tvar that = this;\r\n\t\t\tvar dataId  =e.currentTarget.dataset.id;\r\n\t\t\tvar r=confirm(\"确认删除该数据吗？\");\r\n\t\t\tif(r==true){\r\n\t\t\t\t$.ajax({\r\n\t\t\t\t\ttype : 'get',\r\n\t\t\t\t\turl : this.REQUEST_URL+\"/admin/reply_msg/del\",\r\n\t\t\t\t\tasync: false,\r\n\t\t\t\t\tdata : {\r\n\t\t\t\t\t\t\"loginToken\":that.currentLoginToken,\r\n\t\t\t\t\t\t\"id\":dataId\r\n\t\t\t\t\t},\r\n\t\t\t\t\tsuccess : function(result) {\r\n\t\t\t\t\t\talert(result.msg);\r\n\t\t\t\t\t\tif(result.code==1){\r\n\t\t\t\t\t\t\tthat.ajaxList(1);\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t}\r\n\t\t\t\t});\r\n\t\t\t}\r\n\t\t},\r\n\t\tajaxCount(){\r\n\t\t\tvar that = this;\r\n\t\t\tvar rs = null;\r\n\t\t\tvar replyContent = that.replyContent;\r\n\t\t\tvar replyTime1 = date_utils.getDomVal(\"replyTime1\");\r\n\t\t\tvar replyTime2 = date_utils.getDomVal(\"replyTime2\");\r\n\t\t\t$.ajax({\r\n\t\t\t\ttype : 'get',\r\n\t\t\t\turl : this.REQUEST_URL+'/admin/reply_msg/queryCount',\r\n\t\t\t\tasync: false,\r\n\t\t\t\tdata : {\r\n\t\t\t\t\t\"loginToken\":that.currentLoginToken,\r\n\t\t\t\t\t\"replyContent\":replyContent,\r\n\t\t\t\t\t\"replyTime1\":replyTime1,\r\n\t\t\t\t\t\"replyTime2\":replyTime2,\r\n\t\t\t\t},\r\n\t\t\t\tsuccess : function(result) {\r\n\t\t\t\t\trs = result;\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t\treturn rs;\r\n\t\t},\r\n\t\tajaxList(page){\r\n\t\t\tvar that = this;\r\n\t\t\tif(page==undefined||page==null){\r\n\t\t\t\tpage=1;\r\n